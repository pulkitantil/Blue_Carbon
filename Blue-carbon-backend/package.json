{
  "name": "blue-carbon-registry",
  "version": "1.0.0",
  "description": "Blockchain-based Blue Carbon Registry and MRV System on Ethereum Sepolia",
  "type": "module",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "indexer": "node backend/services/blockchainIndexer.js",
    "compile": "npx hardhat compile --config hardhat.config.cjs",
    "test": "npx hardhat test --config hardhat.config.cjs",
    "test:gas": "REPORT_GAS=true npx hardhat test --config hardhat.config.cjs",
    "deploy:sepolia": "npx hardhat run scripts/deploy.cjs --network sepolia --config hardhat.config.cjs",
    "deploy:local": "npx hardhat run scripts/deploy.cjs --network hardhat --config hardhat.config.cjs",
    "node:local": "npx hardhat node --config hardhat.config.cjs"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "hh2",
    "chai": "^4.3.10",
    "hardhat": "^2.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
